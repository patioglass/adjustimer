{
    "name": "AdjusTimer",
    "manifest_version": 2,
    "version": "1.2",
    "description": "Amazon Prime Video/Tverの現在の再生時間を別ウィンドウで映す拡張",
    "content_scripts": [
        {
            "matches": [ "https://www.amazon.co.jp/*", "https://tver.jp/corner/*" ],
            "run_at": "document_end",
            "js": ["content_scripts.js"]
        }
    ],
    "background":{
        "scripts":[
          "event.js"
        ],
        "persistent": false
    },
    "permissions": [
        "contextMenus"
    ],
    "icons": {
        "16": "img/icon16.png",
        "48": "img/icon48.png",
        "128": "img/icon128.png"
    }
}